{
  "manifest_version": 3,
  "name": "SoundCloud Insights Overlay",
  "version": "1.0.0",
  "description": "Intercept GraphQL from insights-ui.soundcloud.com and show data overlay with CSV export.",
  "host_permissions": [
    "https://*.soundcloud.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.soundcloud.com/*"],
      "js": ["hook.mainworld.js"],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.soundcloud.com/*"],
      "js": ["overlay.js"],
      "css": ["overlay.css"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ]
}

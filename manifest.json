{
  "manifest_version": 3,
  "name": "SoundCloud Insights Overlay",
  "version": "2.0.1",
  "description": "Capture supported SoundCloud 4 Artists GraphQL insight datasets, show an overlay, and forward normalized rows to Tools.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.soundcloud.com/*",
    "https://tools.tornevall.net/*",
    "https://tools.tornevall.com/*"
  ],
  "action": {
    "default_title": "SoundCloud Insights Overlay",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "scx-insights-mark.svg"
      ],
      "matches": [
        "https://*.soundcloud.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.soundcloud.com/*"],
      "js": ["hook.mainworld.js"],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.soundcloud.com/*"],
      "js": ["overlay.js"],
      "css": ["overlay.css"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ]
}
